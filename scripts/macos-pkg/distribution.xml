<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="2">
    <title>Traktor</title>
    <organization>com.servmask</organization>
    <options customize="never" require-scripts="false" hostArchitectures="x86_64,arm64"/>

    <welcome file="welcome.html" mime-type="text/html"/>
    <conclusion file="conclusion.html" mime-type="text/html"/>

    <choices-outline>
        <line choice="default"/>
    </choices-outline>

    <choice id="default" title="Traktor" description="WordPress .wpress backup extractor">
        <pkg-ref id="com.servmask.traktor"/>
    </choice>

    <pkg-ref id="com.servmask.traktor"
             version="0.0.0"
             installKBytes="50000"
             auth="root">#traktor-component.pkg</pkg-ref>
</installer-gui-script>
